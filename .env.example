# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get it from @userinfobot)
ALLOWED_USER_ID=your_user_id_here

# Path to Claude CLI binary (default: "claude" from PATH)
# CLAUDE_PATH=/usr/local/bin/claude

# Default working directory for Claude (default: your home directory)
# DEFAULT_CWD=/home/user/projects

# Timeout in seconds for Claude CLI execution (default: 300)
# CLAUDE_TIMEOUT=300
